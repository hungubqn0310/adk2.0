# Bắt buộc: Gemini API key (AI Studio)
GOOGLE_API_KEY=your_gemini_api_key_here

# Tùy chọn — cng_product đọc các biến này (có default trong code nếu bỏ trống)
# GOOGLE_GEMINI_BASE_URL=
# DEFAULT_MMVN_STORE_ID=
# DEFAULT_MMVN_STORE_URL=

# Postgres session store (compose tự set; chỉ override khi chạy ngoài compose)
# SESSION_SERVICE_URI=postgresql+psycopg2://adk:adk@postgres:5432/adk
